/* 全局样式 - Teal 主题 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 通用颜色 */
.text-danger { color: #F44336; }
.text-warning { color: #FF9800; }
.text-safe { color: #4CAF50; }
.text-gray { color: #999999; }
.text-teal { color: #009688; }

/* 通用间距 */
.page-container {
  padding: 0 32rpx;
}

/* FAB 按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background-color: #009688;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 150, 136, 0.4);
  z-index: 100;
}

.fab text {
  font-size: 56rpx;
  line-height: 1;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: #eeeeee;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 16rpx 32rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
