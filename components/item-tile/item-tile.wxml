<view class="item-tile-wrapper">
  <!-- 删除按钮（滑出显示） -->
  <view class="delete-btn" bindtap="onDelete">
    <text>删除</text>
  </view>
  <!-- 主内容 -->
  <view
    class="item-tile"
    style="transform: translateX({{translateX}}rpx)"
    bindtap="onTap"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  >
    <view class="item-content">
      <text class="item-name">{{item.name}}</text>
      <view class="item-subtitle">
        <text class="item-category">{{item.categoryName}}</text>
        <text wx:if="{{item.location}}" class="item-location"> · {{item.location}}</text>
      </view>
      <view wx:if="{{item.expiryDisplayText}}" class="item-expiry">
        <text style="color: {{item.expiryStatusColor}}">{{item.expiryDisplayText}}</text>
      </view>
    </view>
    <view class="item-quantity">
      <text>x{{item.quantity}}{{item.unit}}</text>
    </view>
  </view>
</view>
