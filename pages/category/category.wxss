.page {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.category-list {
  background-color: #ffffff;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.category-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.category-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.lock-icon {
  font-size: 32rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.edit-btn {
  color: #009688;
}

.delete-btn-text {
  color: #F44336;
}

/* 对话框 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.dialog {
  width: 560rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  margin-bottom: 32rpx;
}

.dialog-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.dialog-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.dialog-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
}

.dialog-btn::after {
  border: none;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background-color: #009688;
  color: #ffffff;
}
